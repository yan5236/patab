{
  "name": "patab-introduction",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && node scripts/copy-spa-routes.mjs",
    "deploy": "pnpm build && npx wrangler pages deploy dist --project-name=patab-introduction --branch=main --commit-dirty=true",
